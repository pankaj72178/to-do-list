# Copy this file to ".env" and fill in your real values.
# .env is gitignored so your credentials never get committed.

# MongoDB Atlas connection string (Database → Connect → Drivers).
# Replace <username>, <password>, and the cluster host with yours.
# Add the database name (e.g. /taskdb) before the "?".
MONGODB_URI=mongodb+srv://Pankaj:<Pankaj7217>@<cluster>.mongodb.net/taskdb?retryWrites=true&w=majority

# Optional: port the API listens on (defaults to 3000).
PORT=3000
